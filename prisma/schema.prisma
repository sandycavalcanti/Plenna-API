generator client {
  provider = "prisma-client-js"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
  schemas  = ["BD_PLENNA"]
}

model tb_ai_anotacao {
  ai_anotacao_id         Int        @id @default(autoincrement())
  usuario_id             Int
  ai_anotacao_texto      String
  ai_anotacao_created_at DateTime   @db.Timestamp(6)
  ai_anotacao_updated_at DateTime   @db.Timestamp(6)
  tb_usuario             tb_usuario @relation(fields: [usuario_id], references: [usuario_id], onDelete: Cascade, onUpdate: NoAction)

  @@schema("BD_PLENNA")
}

model tb_categoria {
  categoria_id              Int                         @id @default(autoincrement())
  categoria_nome            String                      @db.VarChar(45)
  categoria_created_at      DateTime                    @db.Timestamp(6)
  categoria_updated_at      DateTime                    @db.Timestamp(6)
  tb_compra                 tb_compra[]
  tb_preferencias_categoria tb_preferencias_categoria[]

  @@schema("BD_PLENNA")
}

model tb_compra {
  compra_id            Int                       @id @default(autoincrement())
  usuario_id           Int
  forma_pagamento_id   Int
  categoria_id         Int
  compra_valor         Decimal                   @db.Decimal(10, 2)
  compra_horario       DateTime                  @db.Timestamp(6)
  compra_fonte         compra_fonte_enum
  compra_classificacao compra_classificacao_enum
  compra_acima_limite  Boolean
  compra_anotacao      String?                   @db.VarChar(200)
  compra_created_at    DateTime                  @db.Timestamp(6)
  compra_updated_at    DateTime                  @db.Timestamp(6)
  compra_deleted_at    DateTime?                 @db.Timestamp(6)
  tb_categoria         tb_categoria              @relation(fields: [categoria_id], references: [categoria_id], onDelete: Cascade, onUpdate: NoAction)
  tb_forma_pagamento   tb_forma_pagamento        @relation(fields: [forma_pagamento_id], references: [forma_pagamento_id], onDelete: Cascade, onUpdate: NoAction)
  tb_usuario           tb_usuario                @relation(fields: [usuario_id], references: [usuario_id], onDelete: Cascade, onUpdate: NoAction)
  tb_compra_item       tb_compra_item[]
  tb_feedback          tb_feedback[]

  @@schema("BD_PLENNA")
}

model tb_compra_item {
  compra_item_id         Int       @id @default(autoincrement())
  compra_id              Int
  compra_item_nome       String    @db.VarChar(45)
  compra_item_valor      Decimal   @db.Decimal(10, 2)
  compra_item_created_at DateTime  @db.Timestamp(6)
  compra_item_updated_at DateTime  @db.Timestamp(6)
  tb_compra              tb_compra @relation(fields: [compra_id], references: [compra_id], onDelete: Cascade, onUpdate: NoAction)

  @@schema("BD_PLENNA")
}

model tb_consentimento {
  consentimento_id         Int                   @id @default(autoincrement())
  consentimento_tipo_id    Int
  usuario_id               Int
  consentimento_status     Boolean
  consentimento_created_at DateTime              @db.Timestamp(6)
  consentimento_updated_at DateTime              @db.Timestamp(6)
  tb_consentimento_tipo    tb_consentimento_tipo @relation(fields: [consentimento_tipo_id], references: [consentimento_tipo_id], onDelete: Cascade, onUpdate: NoAction)
  tb_usuario               tb_usuario            @relation(fields: [usuario_id], references: [usuario_id], onDelete: Cascade, onUpdate: NoAction)

  @@schema("BD_PLENNA")
}

model tb_consentimento_tipo {
  consentimento_tipo_id         Int                @id @default(autoincrement())
  consentimento_tipo_descricao  String             @db.VarChar(45)
  consentimento_tipo_created_at DateTime           @db.Timestamp(6)
  consentimento_tipo_updated_at DateTime           @db.Timestamp(6)
  tb_consentimento              tb_consentimento[]

  @@schema("BD_PLENNA")
}

model tb_email_integracao {
  email_integracao_email_id        Int                 @id @default(autoincrement())
  usuario_id                       Int
  email_integracao_provedor        email_provedor_enum
  email_integracao_refresh_token   String              @db.VarChar(255)
  email_integracao_token_expira_em DateTime            @db.Timestamp(6)
  email_integracao_created_at      DateTime            @db.Timestamp(6)
  email_integracao_updated_at      DateTime            @db.Timestamp(6)
  tb_usuario                       tb_usuario          @relation(fields: [usuario_id], references: [usuario_id], onDelete: Cascade, onUpdate: NoAction)

  @@schema("BD_PLENNA")
}

model tb_feedback {
  feedback_ia_id            Int                         @id @default(autoincrement())
  compra_id                 Int
  feedback_classificacao    feedback_classificacao_enum
  feedback_usuario_discorda Boolean
  feedback_created_at       DateTime                    @db.Timestamp(6)
  feedback_updated_at       DateTime                    @db.Timestamp(6)
  tb_compra                 tb_compra                   @relation(fields: [compra_id], references: [compra_id], onDelete: Cascade, onUpdate: NoAction)

  @@schema("BD_PLENNA")
}

model tb_forma_pagamento {
  forma_pagamento_id         Int         @id @default(autoincrement())
  forma_pagamento_tipo       String      @db.VarChar(45)
  forma_pagamento_updated_at DateTime    @db.Timestamp(6)
  forma_pagamento_created_at DateTime    @db.Timestamp(6)
  tb_compra                  tb_compra[]

  @@schema("BD_PLENNA")
}

model tb_historico {
  historico_id         Int           @id @default(autoincrement())
  usuario_id           Int
  historico_nome       String        @db.VarChar(45)
  historico_created_at DateTime      @db.Timestamp(6)
  historico_updated_at DateTime      @db.Timestamp(6)
  tb_usuario           tb_usuario    @relation(fields: [usuario_id], references: [usuario_id], onDelete: Cascade, onUpdate: NoAction)
  tb_mensagem          tb_mensagem[]

  @@schema("BD_PLENNA")
}

model tb_mensagem {
  mensagem_id            Int          @id @default(autoincrement())
  historico_id           Int
  mensagem_remetente     Boolean
  mensagem_texto         String
  mensagem_imagem        Bytes?
  mensagem_possui_imagem Boolean
  mensagem_created_at    DateTime     @db.Timestamp(6)
  mensagem_updated_at    DateTime     @db.Timestamp(6)
  tb_historico           tb_historico @relation(fields: [historico_id], references: [historico_id], onDelete: Cascade, onUpdate: NoAction)

  @@schema("BD_PLENNA")
}

model tb_meta {
  meta_id         Int        @id @default(autoincrement())
  usuario_id      Int
  meta_nome       String     @db.VarChar(45)
  meta_descricao  String
  meta_valor      Decimal    @db.Decimal(10, 2)
  meta_data       DateTime   @db.Date
  meta_created_at DateTime   @db.Timestamp(6)
  meta_updated_at DateTime   @db.Timestamp(6)
  tb_usuario      tb_usuario @relation(fields: [usuario_id], references: [usuario_id], onDelete: Cascade, onUpdate: NoAction)

  @@schema("BD_PLENNA")
}

model tb_metricas_comportamento {
  metricas_comportamento_id                    Int        @id @default(autoincrement())
  usuario_id                                   Int
  metricas_comportamento_media_gasto           Decimal    @db.Decimal(10, 2)
  metricas_comportamento_media_valor_compra    Decimal    @db.Decimal(10, 2)
  metricas_comportamento_frequencia_compra     Int
  metricas_comportamento_media_tempo_ecommerce Decimal    @db.Decimal(10, 2)
  metricas_comportamento_limite_impulso        Decimal    @db.Decimal(10, 2)
  metricas_comportamento_limite_excesso        Decimal    @db.Decimal(10, 2)
  metricas_comportamento_periodo_referencia    DateTime   @db.Timestamp(6)
  metricas_comportamento_created_at            DateTime   @db.Timestamp(6)
  metricas_comportamento_updated_at            DateTime   @db.Timestamp(6)
  tb_usuario                                   tb_usuario @relation(fields: [usuario_id], references: [usuario_id], onDelete: Cascade, onUpdate: NoAction)

  @@schema("BD_PLENNA")
}

model tb_preferencias {
  preferencias_id            Int                         @id @default(autoincrement())
  usuario_id                 Int
  preferencias_meta_valor    Decimal?                    @db.Decimal(10, 2)
  preferencias_meta_tempo    Decimal?                    @db.Decimal(10, 2)
  preferencias_limite_compra Decimal?                    @db.Decimal(10, 2)
  preferencias_created_at    DateTime                    @db.Timestamp(6)
  preferencias_updated_at    DateTime                    @db.Timestamp(6)
  tb_usuario                 tb_usuario                  @relation(fields: [usuario_id], references: [usuario_id], onDelete: Cascade, onUpdate: NoAction)
  tb_preferencias_categoria  tb_preferencias_categoria[]

  @@schema("BD_PLENNA")
}

model tb_preferencias_categoria {
  preferencias_categoria_id          Int             @id @default(autoincrement())
  categoria_id                       Int
  preferencias_id                    Int
  preferencias_categoria_meta_mensal Decimal         @db.Decimal(10, 2)
  preferencias_categoria_created_at  DateTime        @db.Timestamp(6)
  preferencias_categoria_updated_at  DateTime        @db.Timestamp(6)
  tb_categoria                       tb_categoria    @relation(fields: [categoria_id], references: [categoria_id], onDelete: Cascade, onUpdate: NoAction)
  tb_preferencias                    tb_preferencias @relation(fields: [preferencias_id], references: [preferencias_id], onDelete: Cascade, onUpdate: NoAction)

  @@schema("BD_PLENNA")
}

model tb_tempo_uso {
  tempo_uso_id         Int        @id @default(autoincrement())
  usuario_id           Int
  tempo_uso_nome       String     @db.VarChar(45)
  tempo_uso_minutos    Decimal    @db.Decimal(10, 2)
  tempo_uso_data       DateTime   @db.Timestamp(6)
  tempo_uso_created_at DateTime   @db.Timestamp(6)
  tempo_uso_updated_at DateTime   @db.Timestamp(6)
  tb_usuario           tb_usuario @relation(fields: [usuario_id], references: [usuario_id], onDelete: Cascade, onUpdate: NoAction)

  @@schema("BD_PLENNA")
}

model tb_usuario {
  usuario_id                Int                         @id @default(autoincrement())
  usuario_email             String                      @unique @db.VarChar(64)
  usuario_senha             String                      @db.VarChar(255)
  usuario_nome              String                      @db.VarChar(45)
  usuario_status            Boolean
  usuario_created_at        DateTime                    @db.Timestamp(6)
  usuario_updated_at        DateTime                    @db.Timestamp(6)
  usuario_deleted_at        DateTime?                   @db.Timestamp(6)
  tb_ai_anotacao            tb_ai_anotacao[]
  tb_compra                 tb_compra[]
  tb_consentimento          tb_consentimento[]
  tb_email_integracao       tb_email_integracao[]
  tb_historico              tb_historico[]
  tb_meta                   tb_meta[]
  tb_metricas_comportamento tb_metricas_comportamento[]
  tb_preferencias           tb_preferencias[]
  tb_tempo_uso              tb_tempo_uso[]

  @@schema("BD_PLENNA")
}

enum compra_classificacao_enum {
  PENDENTE
  IMPULSIVA
  NAO_IMPULSIVA @map("NAO IMPULSIVA")

  @@schema("BD_PLENNA")
}

enum compra_fonte_enum {
  EMAIL
  MANUAL
  APP
  SITE

  @@schema("BD_PLENNA")
}

enum email_provedor_enum {
  GMAIL
  OUTLOOK

  @@schema("BD_PLENNA")
}

enum feedback_classificacao_enum {
  IMPULSIVA
  NAO_IMPULSIVA @map("NAO IMPULSIVA")

  @@schema("BD_PLENNA")
}
