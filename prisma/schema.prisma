generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
  schemas  = ["public"]
}

model tb_ai_anotacao {
  ai_anotacao_id           Int        @id @default(autoincrement())
  usuario_id               Int
  ai_anotacao_texto        String
  ai_anotacao_data_criacao DateTime   @default(now()) @db.Timestamp(6)
  tb_usuario               tb_usuario @relation(fields: [usuario_id], references: [usuario_id], onDelete: NoAction, onUpdate: NoAction)

  @@schema("public")
}

model tb_categoria {
  categoria_id           Int              @id @default(autoincrement())
  categoria_nome         String           @db.VarChar(45)
  categoria_data_criacao DateTime         @default(now()) @db.Timestamp(6)
  tb_compra_item         tb_compra_item[]
  tb_preferencia         tb_preferencia[]

  @@schema("public")
}

model tb_compra {
  compra_id               Int                       @id @default(autoincrement())
  usuario_id              Int
  forma_pagamento_id      Int
  compra_valor            Decimal                   @db.Decimal(10, 2)
  compra_horario          DateTime                  @db.Timestamp(6)
  compra_fonte            String                    @db.VarChar(45)
  compra_email            Boolean                   @default(true)
  compra_classificacao    compra_classificacao_enum
  compra_acima_limite     Boolean
  compra_usuario_concorda Boolean?
  compra_usuario_anotacao String?
  compra_data_criacao     DateTime                  @default(now()) @db.Timestamp(6)
  tb_forma_pagamento      tb_forma_pagamento        @relation(fields: [forma_pagamento_id], references: [forma_pagamento_id], onDelete: NoAction, onUpdate: NoAction)
  tb_usuario              tb_usuario                @relation(fields: [usuario_id], references: [usuario_id], onDelete: NoAction, onUpdate: NoAction)
  tb_compra_item          tb_compra_item[]

  @@schema("public")
}

model tb_compra_item {
  compra_item_id           Int          @id @default(autoincrement())
  compra_id                Int
  categoria_id             Int
  compra_item_nome         String       @db.VarChar(45)
  compra_item_valor        Decimal      @db.Decimal(10, 2)
  compra_item_data_criacao DateTime     @default(now()) @db.Timestamp(6)
  tb_categoria             tb_categoria @relation(fields: [categoria_id], references: [categoria_id], onDelete: NoAction, onUpdate: NoAction)
  tb_compra                tb_compra    @relation(fields: [compra_id], references: [compra_id], onDelete: NoAction, onUpdate: NoAction)

  @@schema("public")
}

model tb_consentimento {
  consentimento_id           Int                   @id @default(autoincrement())
  consentimento_tipo_id      Int
  usuario_id                 Int
  consentimento_status       Boolean
  consentimento_data_criacao DateTime              @default(now()) @db.Timestamp(6)
  tb_consentimento_tipo      tb_consentimento_tipo @relation(fields: [consentimento_tipo_id], references: [consentimento_tipo_id], onDelete: NoAction, onUpdate: NoAction)
  tb_usuario                 tb_usuario            @relation(fields: [usuario_id], references: [usuario_id], onDelete: NoAction, onUpdate: NoAction)

  @@schema("public")
}

model tb_consentimento_tipo {
  consentimento_tipo_id           Int                @id @default(autoincrement())
  consentimento_tipo_nome         String             @db.VarChar(45)
  consentimento_tipo_data_criacao DateTime           @default(now()) @db.Timestamp(6)
  tb_consentimento                tb_consentimento[]

  @@schema("public")
}

model tb_forma_pagamento {
  forma_pagamento_id           Int         @id @default(autoincrement())
  forma_pagamento_nome         String      @db.VarChar(45)
  forma_pagamento_data_criacao DateTime    @default(now()) @db.Timestamp(6)
  tb_compra                    tb_compra[]

  @@schema("public")
}

model tb_historico {
  historico_id           Int           @id @default(autoincrement())
  usuario_id             Int
  historico_nome         String        @db.VarChar(45)
  historico_data_criacao DateTime      @default(now()) @db.Timestamp(6)
  tb_usuario             tb_usuario    @relation(fields: [usuario_id], references: [usuario_id], onDelete: NoAction, onUpdate: NoAction)
  tb_mensagem            tb_mensagem[]

  @@schema("public")
}

model tb_mensagem {
  mensagem_id               Int          @id @default(autoincrement())
  historico_id              Int
  mensagem_remetente        Boolean
  mensagem_texto            String
  mensagem_imagem           Bytes?
  mensagem_possui_imagem    Boolean      @default(false)
  mensagem_texto_modificado String
  mensagem_data_criacao     DateTime     @default(now()) @db.Timestamp(6)
  mensagem_data_modificacao DateTime     @default(now()) @db.Timestamp(6)
  tb_historico              tb_historico @relation(fields: [historico_id], references: [historico_id], onDelete: NoAction, onUpdate: NoAction)

  @@schema("public")
}

model tb_meta {
  meta_id           Int        @id @default(autoincrement())
  usuario_id        Int
  meta_titulo       String     @db.VarChar(45)
  meta_descricao    String
  meta_valor        Decimal    @db.Decimal(10, 2)
  meta_data         DateTime?  @db.Date
  meta_completado   Boolean    @default(false)
  meta_data_criacao DateTime   @default(now()) @db.Timestamp(6)
  tb_usuario        tb_usuario @relation(fields: [usuario_id], references: [usuario_id], onDelete: NoAction, onUpdate: NoAction)

  @@schema("public")
}

model tb_tempo_uso {
  tempo_uso_id           Int        @id @default(autoincrement())
  usuario_id             Int
  tempo_uso_nome         String     @db.VarChar(45)
  tempo_uso_minutos      Decimal    @db.Decimal(10, 2)
  tempo_uso_data         DateTime   @db.Timestamp(6)
  tempo_uso_data_criacao DateTime   @default(now()) @db.Timestamp(6)
  tb_usuario             tb_usuario @relation(fields: [usuario_id], references: [usuario_id], onDelete: NoAction, onUpdate: NoAction)

  @@schema("public")
}

model tb_usuario {
  usuario_id                Int                @id @default(autoincrement())
  usuario_email             String             @unique @db.VarChar(64)
  usuario_senha             String             @db.VarChar(255)
  usuario_nome              String             @db.VarChar(45)
  usuario_telefone          String?            @db.VarChar(20)
  usuario_data_nascimento   DateTime?          @db.Date
  usuario_status            Boolean            @default(true)
  usuario_limite_compra     Int?
  usuario_meta_valor_mensal Decimal?           @db.Decimal(10, 2)
  usuario_meta_valor_compra Decimal?           @db.Decimal(10, 2)
  usuario_meta_tempo        Int?
  usuario_gatilho_consumo   String?            @db.VarChar(45)
  usuario_tempo_tela        String?            @db.VarChar(20)
  usuario_incomodo_consumo  String?            @db.VarChar(45)
  usuario_data_criacao      DateTime           @default(now()) @db.Timestamp(6)
  tb_ai_anotacao            tb_ai_anotacao[]
  tb_compra                 tb_compra[]
  tb_consentimento          tb_consentimento[]
  tb_historico              tb_historico[]
  tb_integracao             tb_integracao[]
  tb_meta                   tb_meta[]
  tb_metricas               tb_metricas[]
  tb_preferencia            tb_preferencia[]
  tb_tempo_uso              tb_tempo_uso[]

  @@schema("public")
}

model tb_integracao {
  integracao_id               Int                 @id @default(autoincrement())
  usuario_id                  Int
  integracao_nome             String              @db.VarChar(45)
  integracao_provedor         email_provedor_enum
  integracao_access_token     String              @db.VarChar(255)
  integracao_refresh_token    String              @db.VarChar(255)
  integracao_token_expira_em  DateTime            @db.Timestamp(6)
  integracao_data_criacao     DateTime            @default(now()) @db.Timestamp(6)
  integracao_data_modificacao DateTime            @default(now()) @db.Timestamp(6)
  tb_usuario                  tb_usuario          @relation(fields: [usuario_id], references: [usuario_id], onDelete: NoAction, onUpdate: NoAction)

  @@schema("public")
}

model tb_metricas {
  metricas_id                 Int        @id @default(autoincrement())
  usuario_id                  Int
  metricas_media_gasto        Decimal    @db.Decimal(10, 2)
  metricas_media_valor_compra Decimal    @db.Decimal(10, 2)
  metricas_frequencia_compra  Int
  metricas_media_tempo        Decimal    @db.Decimal(10, 2)
  metricas_acima_limite       Boolean        @default(false)
  metricas_periodo_referencia DateTime   @db.Timestamp(6)
  metricas_data_criacao       DateTime   @default(now()) @db.Timestamp(6)
  tb_usuario                  tb_usuario @relation(fields: [usuario_id], references: [usuario_id], onDelete: NoAction, onUpdate: NoAction)

  @@schema("public")
}

model tb_preferencia {
  preferencia_id           Int          @id @default(autoincrement())
  usuario_id               Int
  categoria_id             Int
  preferencia_meta         Decimal      @db.Decimal(10, 2)
  preferencia_data_criacao DateTime     @default(now()) @db.Timestamp(6)
  tb_categoria             tb_categoria @relation(fields: [categoria_id], references: [categoria_id], onDelete: NoAction, onUpdate: NoAction)
  tb_usuario               tb_usuario   @relation(fields: [usuario_id], references: [usuario_id], onDelete: NoAction, onUpdate: NoAction)

  @@schema("public")
}

enum compra_classificacao_enum {
  PENDENTE
  IMPULSIVA
  NAO_IMPULSIVA @map("NAO IMPULSIVA")

  @@schema("public")
}

enum email_provedor_enum {
  GMAIL
  OUTLOOK

  @@schema("public")
}
